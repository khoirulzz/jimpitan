<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme: no action bar, edge-to-edge ready -->
    <style name="Theme.MyApplication" parent="android:Theme.DeviceDefault.NoActionBar">
        <!-- Make status bar and nav bar transparent for edge-to-edge -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- Light status bar icons (dark icons on light bg) - handled by Compose -->
        <item name="android:windowLightStatusBar">false</item>
        <!-- Ensure window is full screen -->
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>
